<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>I LOVE MULIAAA 💖</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;700&family=Poppins:wght@300;600;700&display=swap');
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            height: 100vh;
            background: linear-gradient(-45deg, #ff0000, #ff6b6b, #ff9ff3, #a55eea, #4834d4);
            background-size: 600% 600%;
            animation: gradientBG 15s ease infinite;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            font-family: 'Poppins', sans-serif;
            overflow: hidden;
            position: relative;
        }

        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            25% { background-position: 100% 50%; }
            50% { background-position: 100% 100%; }
            75% { background-position: 0% 100%; }
            100% { background-position: 0% 50%; }
        }

        /* Floating hearts background */
        .hearts-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1;
        }

        .bg-heart {
            position: absolute;
            font-size: 1.5rem;
            opacity: 0.6;
            animation: floatHeart 8s linear infinite;
        }

        @keyframes floatHeart {
            0% {
                transform: translateY(100vh) rotate(0deg) scale(0.5);
                opacity: 0;
            }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% {
                transform: translateY(-100px) rotate(360deg) scale(1.2);
                opacity: 0;
            }
        }

        /* Main container */
        .main-container {
            text-align: center;
            z-index: 10;
            position: relative;
        }

        /* BIG HEART TEXT ANIMATION */
        .love-text {
            font-family: 'Dancing Script', cursive;
            font-size: clamp(4rem, 12vw, 12rem);
            font-weight: 700;
            background: linear-gradient(45deg, #ff1744, #ff6b6b, #ff9ff3, #a55eea, #ffeb3b);
            background-size: 400% 400%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 2rem;
            animation: 
                textShimmer 3s ease-in-out infinite,
                heartbeat 2s ease-in-out infinite,
                textFloat 4s ease-in-out infinite;
            text-shadow: 0 0 30px rgba(255, 107, 107, 0.8);
            filter: drop-shadow(0 0 20px rgba(255, 107, 107, 0.6));
        }

        @keyframes textShimmer {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }

        @keyframes heartbeat {
            0%, 100% { transform: scale(1); }
            15% { transform: scale(1.15); }
            30% { transform: scale(1); }
            45% { transform: scale(1.12); }
            60% { transform: scale(1); }
        }

        @keyframes textFloat {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-15px); }
        }

        /* Subtitle */
        .subtitle {
            font-size: clamp(1.5rem, 4vw, 2.5rem);
            color: rgba(255, 255, 255, 0.95);
            font-weight: 300;
            margin-bottom: 3rem;
            text-shadow: 0 2px 10px rgba(0,0,0,0.3);
            animation: fadeInUp 2s ease-out;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Interactive hearts around text */
        .interactive-hearts {
            position: absolute;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            pointer-events: none;
            z-index: 5;
        }

        .heart-particle {
            position: absolute;
            font-size: 1.2rem;
            pointer-events: none;
            animation: heartBurst 2s ease-out forwards;
        }

        @keyframes heartBurst {
            0% {
                opacity: 1;
                transform: scale(0) rotate(0deg);
            }
            50% {
                opacity: 1;
                transform: scale(1.3) rotate(180deg);
            }
            100% {
                opacity: 0;
                transform: scale(0) rotate(720deg);
            }
        }

        /* Control buttons */
        .controls {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
            flex-wrap: wrap;
            justify-content: center;
        }

        .btn {
            padding: 1rem 2rem;
            font-size: 1.1rem;
            font-weight: 600;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            position: relative;
            overflow: hidden;
        }

        .btn-primary {
            background: linear-gradient(45deg, #ff6b6b, #ff9ff3);
            color: white;
        }

        .btn-secondary {
            background: linear-gradient(45deg, #a55eea, #4834d4);
            color: white;
        }

        .btn:hover {
            transform: translateY(-5px) scale(1.05);
            box-shadow: 0 15px 35px rgba(0,0,0,0.3);
        }

        .btn:active {
            transform: translateY(-2px) scale(1.02);
        }

        /* Particles container */
        #particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 20;
        }

        /* Responsive */
        @media (max-width: 480px) {
            .controls { flex-direction: column; align-items: center; }
            .btn { width: 100%; max-width: 250px; }
        }
    </style>
</head>
<body>
    <div class="hearts-bg" id="heartsBg"></div>
    
    <div class="main-container">
        <div class="love-text" id="loveText">I LOVE MULIAAA</div>
        <div class="subtitle">selamanya dan seterusnya 🤍‼️</div>
        
        <div class="interactive-hearts" id="interactiveHearts"></div>
        
        <div class="controls">
            <button class="btn btn-primary" onclick="createHeartExplosion()">💥 Heart Explosion</button>
            <button class="btn btn-secondary" onclick="toggleAnimation()">🎵 Beat Faster</button>
            <button class="btn btn-primary" onclick="rainLove()">🌧️ Love Rain</button>
        </div>
    </div>

    <div id="particles"></div>

    <script>
        // Floating background hearts
        function createBgHeart() {
            const container = document.getElementById('heartsBg');
            const hearts = ['🤍', '🤍', '🤍', '🤍', '🤍', '🤍'];
            const heart = document.createElement('div');
            heart.className = 'bg-heart';
            heart.innerHTML = hearts[Math.floor(Math.random() * hearts.length)];
            heart.style.left = Math.random() * 100 + 'vw';
            heart.style.animationDuration = (Math.random() * 3 + 5) + 's';
            container.appendChild(heart);
            
            setTimeout(() => heart.remove(), 9000);
        }

        setInterval(createBgHeart, 1000);

        // Heart explosion on hover
        const loveText = document.getElementById('loveText');
        loveText.addEventListener('mouseenter', () => {
            createHeartExplosion(20, true);
        });

        // Heart particles
        function createHeartParticle(x, y) {
            const container = document.getElementById('interactiveHearts');
            const hearts = ['💗', '💗', '💗'];
            const heart = document.createElement('div');
            heart.className = 'heart-particle';
            heart.innerHTML = hearts[Math.floor(Math.random() * hearts.length)];
            heart.style.left = x + 'px';
            heart.style.top = y + 'px';
            container.appendChild(heart);
            
            setTimeout(() => heart.remove(), 2000);
        }

        // Main explosion function
        function createHeartExplosion(count = 50, fromText = false) {
            const rect = fromText ? loveText.getBoundingClientRect() : {
                left: window.innerWidth / 2,
                top: window.innerHeight / 2
            };
            
            for(let i = 0; i < count; i++) {
                setTimeout(() => {
                    const angle = (i / count) * Math.PI * 2;
                    const velocity = 100 + Math.random() * 100;
                    const vx = Math.cos(angle) * velocity;
                    const vy = Math.sin(angle) * velocity;
                    
                    const particle = document.createElement('div');
                    particle.innerHTML = ['🤍', '🤍', '🤍'][Math.floor(Math.random()*3)];
                    particle.style.position = 'fixed';
                    particle.style.left = rect.left + rect.width/2 + 'px';
                    particle.style.top = rect.top + rect.height/2 + 'px';
                    particle.style.fontSize = '1.5rem';
                    particle.style.pointerEvents = 'none';
                    particle.style.zIndex = '1000';
                    particle.style.transition = 'all 2s ease-out';
                    document.getElementById('particles').appendChild(particle);
                    
                    requestAnimationFrame(() => {
                        particle.animate([
                            { transform: `translate(${vx}px, ${vy}px) scale(1)`, opacity: 1 },
                            { transform: `translate(${vx*1.5}px, ${vy*1.5}px) scale(0)`, opacity: 0 }
                        ], {
                            duration: 2000,
                            easing: 'ease-out'
                        }).onfinish = () => particle.remove();
                    });
                }, i * 30);
            }
        }

        // Toggle animation speed
        let fastBeat = false;
        function toggleAnimation() {
            fastBeat = !fastBeat;
            const animDuration = fastBeat ? '1s' : '2s';
            loveText.style.animation = fastBeat 
                ? 'textShimmer 1.5s ease-in-out infinite, heartbeat 1s ease-in-out infinite, textFloat 2s ease-in-out infinite'
                : 'textShimmer 3s ease-in-out infinite, heartbeat 2s ease-in-out infinite, textFloat 4s ease-in-out infinite';
            
            const btn = event.target;
            btn.textContent = fastBeat ? '😻 Slower Beat' : '🎵 Beat Faster';
            btn.style.background = fastBeat 
                ? 'linear-gradient(45deg, #00b894, #00cec9)' 
                : 'linear-gradient(45deg, #a55eea, #4834d4)';
        }

        // Love rain
        function rainLove() {
            for(let i = 0; i < 100; i++) {
                setTimeout(() => {
                    const heart = document.createElement('div');
                    heart.innerHTML = '🤍';
                    heart.style.position = 'fixed';
                    heart.style.left = Math.random() * 100 + 'vw';
                    heart.style.top = '-5%';
                    heart.style.fontSize = '1.8rem';
                    heart.style.pointerEvents = 'none';
                    heart.style.zIndex = '1000';
                    heart.style.animation = 'loveRain 4s linear forwards';
                    document.body.appendChild(heart);
                    setTimeout(() => heart.remove(), 4000);
                }, i * 50);
            }
        }

        // Add loveRain animation
        const style = document.createElement('style');
        style.textContent = `
            @keyframes loveRain {
                to {
                    transform: translateY(110vh) rotate(720deg);
                    opacity: 0;
                }
            }
        `;
        document.head.appendChild(style);

        // Auto heart explosions every 10 seconds
        setInterval(() => {
            if(Math.random() > 0.3) createHeartExplosion(30);
        }, 10000);
    </script>
</body>
</html>